# ── Dev Server ──────────────────────────────────────────────────────────────
# Port the Vite dev server listens on. Override for QA/parallel dev:
#   VITE_DEV_PORT=5180 npm run dev
VITE_DEV_PORT=5173

# Backend port used by the Vite dev server proxy. The frontend makes
# same-origin requests to /v1/api and /health, which Vite proxies here.
# Override when backend runs on alt port:
#   VITE_BACKEND_PORT=5181 npm run dev
VITE_BACKEND_PORT=8080

# ── API ────────────────────────────────────────────────────────────────────
# API path prefix for API calls. Defaults to /v1/api.
VITE_API_BASE=/v1/api

# ── App ────────────────────────────────────────────────────────────────────
# Application display name shown in the browser tab and UI headings.
VITE_APP_NAME=Resume App