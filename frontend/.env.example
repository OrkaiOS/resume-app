# ── API ────────────────────────────────────────────────────────────────────
# Base URL of the backend API server (required).
# In development this is typically the Go backend on port 8080.
VITE_API_URL=http://localhost:8080

# ── App ────────────────────────────────────────────────────────────────────
# Application display name shown in the browser tab and UI headings.
VITE_APP_NAME=Resume App