# ── Server ────────────────────────────────────────────────────────────────
# TCP port the Gin server listens on (required).
BACKEND_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────
# Filesystem path to the SQLite database file.
# Default: $HOME/.orkai-resume/data.db (when unset or empty).
DB_PATH=data/resume.db

# ── LLM ───────────────────────────────────────────────────────────────────
# LLM backend provider (e.g. "ollama", "openai", "anthropic").
LLM_PROVIDER=ollama

# Model name to call on the selected provider.
LLM_MODEL=llama3.2

# API key for OpenAI (required when LLM_PROVIDER=openai).
OPENAI_API_KEY=sk-...

# API key for Anthropic (required when LLM_PROVIDER=anthropic).
ANTHROPIC_API_KEY=sk-ant-...

# ── Output ────────────────────────────────────────────────────────────────
# Directory where generated PDFs are written.
OUTPUT_DIR=generated

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# In development use "http://localhost:5173" (Vite dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Orkai ──────────────────────────────────────────────────────────────────
# URL of the orkai daemon health endpoint (required).
ORKAI_HEALTH_URL=http://127.0.0.1:9090/health

# Base URL for the orkai MCP API (default: http://127.0.0.1:8787/v2/sse).
ORKAI_MCP_URL=http://127.0.0.1:8787/v2/sse

# Auth token for the orkai MCP API. Required for onboarding orkai-setup.
# Auto-detected from cursor/cline/opencode MCP config files if not set.
ORKAI_MCP_TOKEN=orkai-token-here